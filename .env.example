# OpenAI API'yi kullanabilmek için temel ayarlar
OPENAI_API_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="your-openai-api-key"

# OpenAI API'nin tüm özelliklerini aktif etmek için model ve parametreler
OPENAI_MODEL="gpt-4-turbo"
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096
OPENAI_TOP_P=1.0
OPENAI_FREQUENCY_PENALTY=0.0
OPENAI_PRESENCE_PENALTY=0.0

# Embeddings için OpenAI ayarları
OPENAI_EMBEDDINGS_MODEL="text-embedding-ada-002"

# OpenAI DALL·E desteği (görsel üretimi aktif etmek için)
DALLE_API_BASE_URL="https://api.openai.com/v1/images/generations"
DALLE_ENABLED=true

# Whisper API için sesli komut desteği
WHISPER_API_BASE_URL="https://api.openai.com/v1/audio/transcriptions"
WHISPER_ENABLED=true

# Open-webui ile uyumlu ollama ayarları
OLLAMA_BASE_URL="http://localhost:11434"

# Güvenlik ve izleme ayarları
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
